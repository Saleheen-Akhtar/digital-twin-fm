# Database
POSTGRES_USER=dtfm_user
POSTGRES_PASSWORD=dtfm_pass
POSTGRES_DB=dtfm_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Set to "true" in production to require TLS to Postgres. Uses a
# verifying client (rejects unauthorized certs) — pair with a managed
# Postgres (RDS, Cloud SQL) that ships a real CA bundle.
POSTGRES_SSL=false

# Cache / pub-sub (Valkey = BSD drop-in for Redis)
# All services read discrete vars. REDIS_URL fallback works but discrete
# vars are preferred — ioredis URL parsing can cause WRONGPASS with Valkey.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me
MVP_ADMIN_PASSWORD=change-me-in-real-env

# CORS — comma-separated list of allowed origins. Required in production.
# In development, defaults to http://localhost:3000 if unset.
# Example: https://app.example.com,https://staging.example.com
CORS_ORIGIN=

# Dev-only: opt into a deterministic JWT secret (dev-<keyname>) for local
# convenience. NEVER set this in staging or production. When unset in
# development, a random 48-byte secret is generated at boot and logged.
# ALLOW_INSECURE_DEV=1

# AI Providers (example)
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key

# === apps/ai-service ===
# CORS allowlist for direct browser → ai-service traffic. In production
# only the api-gateway should call this service (server-to-server, no
# CORS). An unset value in production = empty allowlist = no browser access.
# In development, defaults to http://localhost:3000.
AI_CORS_ORIGIN=
# Bind address for uvicorn. Override with the Docker service hostname in
# container deployments. 127.0.0.1 is the safe default.
AI_HOST=127.0.0.1
AI_SERVICE_PORT=8000
PYTHONUNBUFFERED=1
LITELLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=*** ANTHROPIC_API_KEY=*** For local: LITELLM_MODEL=ollama/llama3.2

# === apps/ingestion-service ===
# Bind address. 127.0.0.1 is the safe default — only expose 0.0.0.0 when
# behind a reverse proxy / within a trusted Docker network.
INGESTION_HOST=127.0.0.1
INGESTION_PORT=4100
INGESTION_LOG_LEVEL=info
# Comma-separated CORS allowlist. Empty = no browser access (the expected
# posture for a server-to-server ingestion endpoint).
INGESTION_CORS_ORIGIN=
# Shared secret required on every /ingest/* request as
# `X-Ingest-Api-Key: <key>`. Required in staging/production (refuses
# to start without it). In development, a random key is generated and
# logged at boot if this is unset.
# INGEST_API_KEY=replace-me
# MQTT broker (optional — leave blank for HTTP-only MVP)
# MQTT_URL=mqtt://localhost:1883

# IoT (if using real devices later)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# Infisical (optional for local dev)
# INFISICAL_URL=https://app.infisical.com
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
# INFISICAL_PROJECT_ID=

# === apps/web (Next.js) ===
# Server-side base URL for the api-gateway. The web app fetches from this in Server Components.
API_GATEWAY_URL=http://localhost:4000
# Public base URL exposed to the browser bundle. Must be the externally-reachable gateway.
NEXT_PUBLIC_API_URL=http://localhost:4000

# === Root ===
NODE_ENV=development
